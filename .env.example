# Required
GEMINI_API_KEY=your-gemini-api-key

# Model Overrides (all optional - defaults shown)
# GEMINI_MODEL=gemini-3-flash-preview          # Model used for init connection test
# GEMINI_PRO_MODEL=gemini-3.1-pro-preview      # Pro model for reasoning tasks
# GEMINI_FLASH_MODEL=gemini-3-flash-preview     # Flash model for fast tasks
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview  # Image generation model
# GEMINI_VIDEO_MODEL=veo-2.0-generate-001       # Video generation model
# GEMINI_SPEECH_MODEL=gemini-2.5-flash-preview-tts   # Text-to-speech model
# GEMINI_CACHE_MODEL=gemini-2.0-flash-001       # Context caching model

# Output
# GEMINI_OUTPUT_DIR=~/.cache/gemini-mcp/        # Platform-aware default

# Logging
# VERBOSE=false
# QUIET=false

# Tool Selection (optional - load all by default)
# GEMINI_TOOL_PRESET=focused                    # Presets: minimal, text, image, research, media, focused, full
# GEMINI_ENABLED_TOOLS=query,search,image-gen   # Or specify individual tool groups
